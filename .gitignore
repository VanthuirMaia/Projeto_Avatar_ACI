# ── Python ────────────────────────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── Variáveis de ambiente ──────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── RAG — índice gerado (recriar com ingest.py) ────────────────────────────────
Backend/data/rag_store/

# ── Modelos treinados (binários grandes) ──────────────────────────────────────
Backend/data/*.pth

# ── Node / Next.js ────────────────────────────────────────────────────────────
Frontend/node_modules/
Frontend/.next/
Frontend/out/
Frontend/.turbo/

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── Dados persistentes (gerados em runtime, não versionar) ────────────────────
Backend/data/users.json
Backend/data/alunos.json
Backend/data/peis.json
Backend/data/metrics.jsonl
Backend/data/audit.jsonl
